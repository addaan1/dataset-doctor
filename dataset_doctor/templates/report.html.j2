<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Dataset Doctor Report - {{ payload.profile.source_name }}</title>
  <style>
    :root {
      --bg: #f6f1e8;
      --surface: #fffaf2;
      --surface-strong: #ffffff;
      --ink: #1f2933;
      --muted: #5b6773;
      --line: #dfd3c3;
      --accent: #136f63;
      --accent-soft: #d8efe8;
      --warning: #b7791f;
      --warning-soft: #fff3d6;
      --critical: #b2402f;
      --critical-soft: #fde4df;
      --healthy: #136f63;
      --healthy-soft: #ddf4ee;
      --shadow: 0 18px 45px rgba(63, 39, 20, 0.12);
      --radius-lg: 24px;
      --radius-md: 18px;
      --radius-sm: 12px;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: "Trebuchet MS", "Segoe UI", sans-serif;
      color: var(--ink);
      background:
        radial-gradient(circle at top left, rgba(19, 111, 99, 0.12), transparent 30%),
        linear-gradient(180deg, #fff7ed 0%, var(--bg) 100%);
    }

    h1, h2, h3 {
      font-family: Georgia, "Times New Roman", serif;
      margin: 0;
      letter-spacing: -0.02em;
    }

    p { margin: 0; line-height: 1.6; }

    .page {
      max-width: 1180px;
      margin: 0 auto;
      padding: 32px 20px 64px;
    }

    .hero {
      display: grid;
      gap: 18px;
      padding: 28px;
      border-radius: var(--radius-lg);
      background:
        linear-gradient(135deg, rgba(19, 111, 99, 0.95), rgba(19, 111, 99, 0.7)),
        #136f63;
      color: #f7fffd;
      box-shadow: var(--shadow);
      overflow: hidden;
      position: relative;
    }

    .hero::after {
      content: "";
      position: absolute;
      inset: auto -80px -80px auto;
      width: 240px;
      height: 240px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.08);
    }

    .eyebrow {
      font-size: 0.82rem;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      opacity: 0.8;
    }

    .hero-grid {
      display: grid;
      gap: 18px;
      grid-template-columns: 1.8fr 1fr;
      align-items: start;
    }

    .hero-copy p {
      color: rgba(247, 255, 253, 0.86);
      max-width: 60ch;
    }

    .score-card {
      padding: 20px;
      border-radius: var(--radius-md);
      background: rgba(255, 255, 255, 0.12);
      border: 1px solid rgba(255, 255, 255, 0.18);
      backdrop-filter: blur(6px);
    }

    .score-value {
      font-size: 3rem;
      font-weight: 700;
      line-height: 1;
      margin: 10px 0;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 14px;
      border-radius: 999px;
      font-size: 0.86rem;
      font-weight: 700;
      letter-spacing: 0.02em;
    }

    .badge.healthy { background: var(--healthy-soft); color: var(--healthy); }
    .badge.needs-review { background: var(--warning-soft); color: var(--warning); }
    .badge.critical { background: var(--critical-soft); color: var(--critical); }

    .section {
      margin-top: 24px;
      padding: 24px;
      background: var(--surface);
      border: 1px solid rgba(146, 116, 89, 0.12);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow);
    }

    .section-head {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 18px;
    }

    .section-head p {
      color: var(--muted);
      max-width: 58ch;
    }

    .cards {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 14px;
    }

    .card {
      padding: 18px;
      border-radius: var(--radius-md);
      background: var(--surface-strong);
      border: 1px solid rgba(146, 116, 89, 0.12);
    }

    .card-label {
      font-size: 0.82rem;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 10px;
    }

    .card-value {
      font-size: 2rem;
      font-weight: 700;
      line-height: 1.05;
    }

    .card-subtext {
      margin-top: 8px;
      color: var(--muted);
      font-size: 0.94rem;
    }

    .warning-list {
      display: grid;
      gap: 12px;
    }

    .warning-item {
      padding: 16px 18px;
      border-radius: var(--radius-md);
      border: 1px solid transparent;
      background: var(--surface-strong);
    }

    .warning-item.critical {
      background: var(--critical-soft);
      border-color: rgba(178, 64, 47, 0.18);
    }

    .warning-item.warning {
      background: var(--warning-soft);
      border-color: rgba(183, 121, 31, 0.18);
    }

    .warning-item.info {
      background: var(--accent-soft);
      border-color: rgba(19, 111, 99, 0.18);
    }

    .warning-meta {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 8px;
      font-size: 0.9rem;
      font-weight: 700;
    }

    .pill {
      display: inline-block;
      padding: 5px 10px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.65);
      font-size: 0.76rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .two-col {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 18px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.95rem;
      background: var(--surface-strong);
      border-radius: var(--radius-md);
      overflow: hidden;
    }

    th, td {
      text-align: left;
      padding: 12px 14px;
      border-bottom: 1px solid var(--line);
      vertical-align: top;
    }

    thead th {
      font-size: 0.82rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--muted);
      background: rgba(19, 111, 99, 0.06);
    }

    tbody tr:last-child td {
      border-bottom: none;
    }

    .flag-list {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .flag {
      display: inline-flex;
      align-items: center;
      padding: 5px 10px;
      border-radius: 999px;
      background: rgba(19, 111, 99, 0.08);
      color: var(--accent);
      font-size: 0.8rem;
      font-weight: 700;
    }

    .actions {
      display: grid;
      gap: 10px;
      padding-left: 18px;
      margin: 0;
    }

    .muted {
      color: var(--muted);
    }

    @media (max-width: 920px) {
      .hero-grid,
      .cards,
      .two-col {
        grid-template-columns: 1fr;
      }

      .page {
        padding: 18px 14px 42px;
      }

      .section,
      .hero {
        padding: 18px;
      }
    }
  </style>
</head>
<body>
  <main class="page">
    <section class="hero">
      <div class="eyebrow">Dataset Doctor Report</div>
      <div class="hero-grid">
        <div class="hero-copy">
          <h1>{{ payload.profile.source_name }}</h1>
          <p>
            A first-pass data health report covering structure, missingness, duplicates,
            semantic types, numeric summaries, outliers, and rule-based warnings.
          </p>
          <p class="muted" style="color: rgba(247, 255, 253, 0.82);">
            Generated at {{ payload.generated_at }}
          </p>
        </div>
        <aside class="score-card">
          <div class="eyebrow">Health Score</div>
          <div class="score-value">{{ payload.score.value }}</div>
          <span class="badge {{ payload.score.css_modifier }}">{{ payload.score.badge }}</span>
          <p style="margin-top: 12px; color: rgba(247, 255, 253, 0.82);">
            {{ payload.profile.suspicious_column_count }} suspicious columns and
            {{ payload.warnings|length }} generated warnings.
          </p>
        </aside>
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <div>
          <h2>Overview</h2>
          <p>Quick context for the dataset and the most visible structural risks.</p>
        </div>
      </div>
      <div class="cards">
        <article class="card">
          <div class="card-label">Rows</div>
          <div class="card-value">{{ payload.profile.row_count }}</div>
          <div class="card-subtext">Observed records in the CSV.</div>
        </article>
        <article class="card">
          <div class="card-label">Columns</div>
          <div class="card-value">{{ payload.profile.column_count }}</div>
          <div class="card-subtext">Detected fields after normalization.</div>
        </article>
        <article class="card">
          <div class="card-label">Duplicates</div>
          <div class="card-value">{{ payload.profile.duplicate_rows }}</div>
          <div class="card-subtext">{{ "%.1f"|format(payload.profile.duplicate_pct) }}% duplicate rows.</div>
        </article>
        <article class="card">
          <div class="card-label">Outlier Columns</div>
          <div class="card-value">{{ payload.profile.outlier_columns|length }}</div>
          <div class="card-subtext">Numeric fields with IQR outliers.</div>
        </article>
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <div>
          <h2>Warnings</h2>
          <p>Rule-based findings ordered by severity to support quick cleanup decisions.</p>
        </div>
      </div>
      <div class="warning-list">
        {% for warning in payload.warnings %}
          <article class="warning-item {{ warning.level }}">
            <div class="warning-meta">
              <span class="pill">{{ warning.level }}</span>
              <span>{{ warning.title }}</span>
            </div>
            <p>{{ warning.message }}</p>
            <p class="muted" style="margin-top: 8px;">
              Recommended action: {{ warning.recommended_action }}
            </p>
          </article>
        {% endfor %}
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <div>
          <h2>Structure Summary</h2>
          <p>A compact view of type balance and columns that deserve extra attention.</p>
        </div>
      </div>
      <div class="two-col">
        <div class="card">
          <div class="card-label">Type Summary</div>
          <table>
            <thead>
              <tr>
                <th>Semantic Type</th>
                <th>Count</th>
              </tr>
            </thead>
            <tbody>
              {% for semantic_type in ["categorical", "numeric", "boolean", "datetime"] %}
                <tr>
                  <td>{{ semantic_type }}</td>
                  <td>{{ payload.profile.semantic_type_counts.get(semantic_type, 0) }}</td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
        <div class="card">
          <div class="card-label">Suggested Next Steps</div>
          <ol class="actions">
            {% for action in payload.suggested_actions %}
              <li>{{ action }}</li>
            {% endfor %}
          </ol>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <div>
          <h2>Problematic Columns</h2>
          <p>Columns with high missingness, constant values, high-cardinality patterns, or outliers.</p>
        </div>
      </div>
      <table>
        <thead>
          <tr>
            <th>Column</th>
            <th>Type</th>
            <th>Missing</th>
            <th>Unique Ratio</th>
            <th>Flags</th>
          </tr>
        </thead>
        <tbody>
          {% if payload.problematic_columns %}
            {% for column in payload.problematic_columns %}
              <tr>
                <td>{{ column.name }}</td>
                <td>{{ column.semantic_type }}</td>
                <td>{{ "%.1f"|format(column.missing_pct) }}%</td>
                <td>{{ "%.1f"|format(column.unique_ratio * 100) }}%</td>
                <td>
                  <div class="flag-list">
                    {% for flag in column.flags %}
                      <span class="flag">{{ flag }}</span>
                    {% endfor %}
                  </div>
                </td>
              </tr>
            {% endfor %}
          {% else %}
            <tr>
              <td colspan="5">No problematic columns were detected.</td>
            </tr>
          {% endif %}
        </tbody>
      </table>
    </section>

    <section class="section">
      <div class="section-head">
        <div>
          <h2>Numeric Findings</h2>
          <p>Distribution signals for numeric columns using lightweight descriptive statistics and IQR outlier checks.</p>
        </div>
      </div>
      <div class="two-col">
        <table>
          <thead>
            <tr>
              <th>Column</th>
              <th>Min</th>
              <th>Median</th>
              <th>Mean</th>
              <th>Max</th>
              <th>Std</th>
            </tr>
          </thead>
          <tbody>
            {% if payload.numeric_columns %}
              {% for column in payload.numeric_columns %}
                <tr>
                  <td>{{ column.name }}</td>
                  <td>{{ column.numeric_summary.min_value|number }}</td>
                  <td>{{ column.numeric_summary.median|number }}</td>
                  <td>{{ column.numeric_summary.mean|number }}</td>
                  <td>{{ column.numeric_summary.max_value|number }}</td>
                  <td>{{ column.numeric_summary.std|number }}</td>
                </tr>
              {% endfor %}
            {% else %}
              <tr>
                <td colspan="6">No numeric columns available.</td>
              </tr>
            {% endif %}
          </tbody>
        </table>

        <table>
          <thead>
            <tr>
              <th>Column</th>
              <th>Q1</th>
              <th>Q3</th>
              <th>IQR</th>
              <th>Bounds</th>
              <th>Outliers</th>
            </tr>
          </thead>
          <tbody>
            {% if payload.numeric_columns %}
              {% for column in payload.numeric_columns %}
                <tr>
                  <td>{{ column.name }}</td>
                  <td>{{ column.numeric_summary.q1|number }}</td>
                  <td>{{ column.numeric_summary.q3|number }}</td>
                  <td>{{ column.numeric_summary.iqr|number }}</td>
                  <td>
                    {{ column.numeric_summary.lower_bound|number }}
                    to
                    {{ column.numeric_summary.upper_bound|number }}
                  </td>
                  <td>
                    {{ column.numeric_summary.outlier_count }}
                    ({{ "%.1f"|format(column.numeric_summary.outlier_pct) }}%)
                  </td>
                </tr>
              {% endfor %}
            {% else %}
              <tr>
                <td colspan="6">No numeric columns available.</td>
              </tr>
            {% endif %}
          </tbody>
        </table>
      </div>
    </section>
  </main>
</body>
</html>
