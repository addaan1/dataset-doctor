<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Dataset Doctor — {{ payload.profile.source_name }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      /* GitHub-inspired dark palette */
      --bg:            #0d1117;
      --bg-secondary:  #161b22;
      --surface:       #1c2128;
      --surface-hover: #22272e;
      --border:        rgba(139, 148, 158, 0.16);
      --border-bright: rgba(139, 148, 158, 0.3);

      /* Text */
      --ink:   #e6edf3;
      --muted: #8b949e;
      --dim:   #484f58;

      /* Brand: purple/violet GitHub glow */
      --accent:       #a371f7;
      --accent-dark:  #6e40c9;
      --accent-glow:  rgba(163, 113, 247, 0.25);
      --accent-soft:  rgba(163, 113, 247, 0.12);

      /* Status */
      --healthy:      #3fb950;
      --healthy-soft: rgba(63, 185, 80, 0.12);
      --warning:      #d29922;
      --warning-soft: rgba(210, 153, 34, 0.12);
      --critical:     #f85149;
      --critical-soft:rgba(248, 81, 73, 0.12);
      --info:         #58a6ff;
      --info-soft:    rgba(88, 166, 255, 0.12);

      --radius-xl: 20px;
      --radius-lg: 14px;
      --radius-md: 10px;
      --radius-sm: 6px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--bg);
      color: var(--ink);
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* ─── BACKGROUND EFFECTS ─────────────────────────────── */
    body::before {
      content: '';
      position: fixed;
      top: 0; left: 0; right: 0;
      height: 700px;
      background:
        radial-gradient(ellipse 80% 60% at 50% -10%, rgba(110, 64, 201, 0.3) 0%, transparent 70%),
        radial-gradient(ellipse 60% 40% at 80% 10%, rgba(163, 113, 247, 0.1) 0%, transparent 60%);
      pointer-events: none;
      z-index: 0;
    }

    /* ─── LAYOUT ─────────────────────────────────────────── */
    .layout {
      position: relative;
      z-index: 1;
      max-width: 1140px;
      margin: 0 auto;
      padding: 0 24px 100px;
    }

    /* ─── TOPBAR ─────────────────────────────────────────── */
    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 20px 0;
      border-bottom: 1px solid var(--border);
      margin-bottom: 56px;
    }

    .topbar-brand {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .topbar-icon {
      width: 32px;
      height: 32px;
      border-radius: 8px;
      background: linear-gradient(135deg, var(--accent-dark), var(--accent));
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
      box-shadow: 0 0 20px var(--accent-glow);
    }

    .topbar-name {
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--ink);
      letter-spacing: -0.01em;
    }

    .topbar-meta {
      font-size: 0.8rem;
      color: var(--muted);
    }

    /* ─── HERO ───────────────────────────────────────────── */
    .hero {
      text-align: center;
      padding: 20px 0 56px;
    }

    .hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 4px 12px;
      border-radius: 999px;
      border: 1px solid rgba(163, 113, 247, 0.4);
      background: rgba(163, 113, 247, 0.08);
      color: var(--accent);
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: 20px;
    }

    .hero-title {
      font-size: clamp(2rem, 5vw, 3.2rem);
      font-weight: 800;
      letter-spacing: -0.04em;
      line-height: 1.1;
      color: var(--ink);
      margin-bottom: 14px;
    }

    .hero-title span {
      background: linear-gradient(120deg, #a371f7, #79c0ff, #a371f7);
      background-size: 200% auto;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: shimmer 4s linear infinite;
    }

    @keyframes shimmer {
      to { background-position: 200% center; }
    }

    .hero-sub {
      color: var(--muted);
      font-size: 1rem;
      max-width: 500px;
      margin: 0 auto;
      line-height: 1.7;
    }

    /* ─── SCORE SECTION ──────────────────────────────────── */
    .score-section {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      margin-bottom: 48px;
    }

    @media (max-width: 760px) { .score-section { grid-template-columns: 1fr; } }

    /* Main score card */
    .main-score-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-xl);
      padding: 36px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .main-score-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 80% 60% at 50% 0%, var(--accent-glow), transparent 70%);
      pointer-events: none;
    }

    .score-ring-wrap { position: relative; margin-bottom: 20px; }

    .score-ring {
      width: 140px;
      height: 140px;
      filter: drop-shadow(0 0 24px var(--accent-glow));
    }

    .score-ring-val {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }

    .score-number {
      font-size: 2.6rem;
      font-weight: 800;
      letter-spacing: -0.05em;
      line-height: 1;
      color: var(--ink);
    }

    .score-denom {
      font-size: 0.85rem;
      color: var(--muted);
      font-weight: 500;
    }

    .score-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 5px 14px;
      border-radius: 999px;
      font-size: 0.82rem;
      font-weight: 600;
      letter-spacing: 0.03em;
      margin-top: 4px;
      margin-bottom: 12px;
    }
    .score-badge.healthy      { background: var(--healthy-soft);  color: var(--healthy);  border: 1px solid rgba(63,185,80,0.3); }
    .score-badge.needs-review { background: var(--warning-soft);  color: var(--warning);  border: 1px solid rgba(210,153,34,0.3); }
    .score-badge.critical     { background: var(--critical-soft); color: var(--critical); border: 1px solid rgba(248,81,73,0.3); }

    .score-meta-row {
      display: flex;
      gap: 20px;
      font-size: 0.8rem;
      color: var(--muted);
    }

    .score-meta-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 2px;
    }
    .score-meta-item strong { font-size: 1.1rem; color: var(--ink); font-weight: 700; }

    /* Dimension bars card */
    .dim-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-xl);
      padding: 28px 32px;
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .dim-card-title {
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--muted);
      padding-bottom: 12px;
      border-bottom: 1px solid var(--border);
    }

    .dim-row {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .dim-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .dim-label {
      font-size: 0.87rem;
      font-weight: 500;
      color: var(--ink);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .dim-icon {
      width: 22px;
      height: 22px;
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 12px;
    }

    .dim-val {
      font-size: 0.85rem;
      font-weight: 700;
      color: var(--ink);
    }

    .dim-track {
      height: 7px;
      background: rgba(139, 148, 158, 0.12);
      border-radius: 99px;
      overflow: hidden;
    }

    .dim-fill {
      height: 100%;
      border-radius: 99px;
      transition: width 1s ease;
    }
    .dim-fill.ok   { background: linear-gradient(90deg, #3fb950, #56d364); }
    .dim-fill.warn { background: linear-gradient(90deg, #d29922, #e3b341); }
    .dim-fill.crit { background: linear-gradient(90deg, #f85149, #ff7b72); }

    /* ─── SECTION ────────────────────────────────────────── */
    .section {
      margin-bottom: 48px;
    }

    .section-header {
      display: flex;
      align-items: flex-start;
      gap: 14px;
      margin-bottom: 24px;
      padding-bottom: 16px;
      border-bottom: 1px solid var(--border);
    }

    .section-icon {
      width: 36px;
      height: 36px;
      border-radius: var(--radius-md);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      flex-shrink: 0;
      margin-top: 2px;
    }

    .section-text h2 {
      font-size: 1.15rem;
      font-weight: 700;
      color: var(--ink);
      letter-spacing: -0.02em;
      margin-bottom: 3px;
    }

    .section-text p {
      font-size: 0.875rem;
      color: var(--muted);
    }

    /* ─── STAT CARDS ─────────────────────────────────────── */
    .stat-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 14px;
    }

    @media (max-width: 760px) { .stat-grid { grid-template-columns: repeat(2, 1fr); } }

    .stat-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 20px 22px;
      transition: border-color 0.2s ease, transform 0.2s ease;
    }

    .stat-card:hover {
      border-color: var(--border-bright);
      transform: translateY(-2px);
    }

    .stat-label {
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--muted);
      margin-bottom: 10px;
    }

    .stat-value {
      font-size: 2rem;
      font-weight: 800;
      letter-spacing: -0.04em;
      color: var(--ink);
      line-height: 1;
      margin-bottom: 6px;
    }

    .stat-sub {
      font-size: 0.8rem;
      color: var(--muted);
    }

    /* ─── WARNING ITEMS ──────────────────────────────────── */
    .warning-list { display: flex; flex-direction: column; gap: 10px; }

    .warning-item {
      display: flex;
      gap: 16px;
      align-items: flex-start;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 16px 20px;
      transition: border-color 0.2s ease;
    }

    .warning-item:hover { border-color: var(--border-bright); }

    .warning-item.critical { border-left: 3px solid var(--critical); }
    .warning-item.warning  { border-left: 3px solid var(--warning);  }
    .warning-item.info     { border-left: 3px solid var(--info);     }

    .warning-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      margin-top: 6px;
      flex-shrink: 0;
    }
    .warning-dot.critical { background: var(--critical); box-shadow: 0 0 8px var(--critical); }
    .warning-dot.warning  { background: var(--warning);  box-shadow: 0 0 8px var(--warning);  }
    .warning-dot.info     { background: var(--info);     box-shadow: 0 0 8px var(--info);     }

    .warning-body { flex: 1; }

    .warning-top {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 4px;
    }

    .warning-pill {
      padding: 2px 8px;
      border-radius: 999px;
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    .warning-pill.critical { background: var(--critical-soft); color: var(--critical); }
    .warning-pill.warning  { background: var(--warning-soft);  color: var(--warning);  }
    .warning-pill.info     { background: var(--info-soft);     color: var(--info);     }

    .warning-title-text {
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--ink);
    }

    .warning-message { font-size: 0.85rem; color: var(--muted); line-height: 1.6; }

    .warning-action {
      margin-top: 8px;
      font-size: 0.8rem;
      color: var(--dim);
      padding: 8px 12px;
      background: rgba(139, 148, 158, 0.06);
      border-radius: var(--radius-sm);
    }

    .warning-action strong { color: var(--muted); }

    /* ─── TABLES ─────────────────────────────────────────── */
    .table-wrap {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      overflow: hidden;
    }

    table {
      width: 100%;
      border-collapse: collapse;
    }

    thead th {
      padding: 12px 16px;
      text-align: left;
      font-size: 0.73rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--muted);
      background: rgba(139, 148, 158, 0.06);
      border-bottom: 1px solid var(--border);
    }

    tbody td {
      padding: 13px 16px;
      font-size: 0.875rem;
      border-bottom: 1px solid var(--border);
      color: var(--ink);
      vertical-align: middle;
    }

    tbody tr:last-child td { border-bottom: none; }

    tbody tr {
      transition: background 0.15s ease;
    }

    tbody tr:hover { background: rgba(139, 148, 158, 0.04); }

    .code-chip {
      font-family: 'SFMono-Regular', Consolas, monospace;
      background: rgba(139, 148, 158, 0.1);
      color: var(--muted);
      border: 1px solid var(--border);
      padding: 2px 8px;
      border-radius: 5px;
      font-size: 0.78rem;
    }

    /* ─── FLAGS ──────────────────────────────────────────── */
    .flag-list { display: flex; flex-wrap: wrap; gap: 5px; }

    .flag {
      font-size: 0.72rem;
      font-weight: 600;
      padding: 3px 8px;
      border-radius: 999px;
      border: 1px solid;
    }
    .flag.missing  { background: var(--critical-soft); color: var(--critical); border-color: rgba(248,81,73,0.3); }
    .flag.outliers { background: var(--warning-soft);  color: var(--warning);  border-color: rgba(210,153,34,0.3); }
    .flag.default  { background: rgba(139,148,158,0.1); color: var(--muted); border-color: var(--border); }

    /* ─── TWO COL ────────────────────────────────────────── */
    .two-col {
      display: grid;
      grid-template-columns: 1fr 1.5fr;
      gap: 20px;
    }
    @media ( max-width: 760px) { .two-col { grid-template-columns: 1fr; } }

    /* ─── ACTION LIST CARD ───────────────────────────────── */
    .action-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 24px 28px;
    }

    .action-card-title {
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--muted);
      margin-bottom: 16px;
      padding-bottom: 12px;
      border-bottom: 1px solid var(--border);
    }

    .action-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .action-list li {
      display: flex;
      gap: 10px;
      font-size: 0.875rem;
      color: var(--ink);
      line-height: 1.5;
    }

    .action-list li::before {
      content: '→';
      color: var(--accent);
      font-weight: 700;
      flex-shrink: 0;
    }

    /* ─── TYPE DOUGHNUT TABLE  ───────────────────────────── */
    .type-row {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 10px 0;
      border-bottom: 1px solid var(--border);
    }
    .type-row:last-child { border-bottom: none; }

    .type-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      flex-shrink: 0;
    }
    .type-dot.categorical { background: #a371f7; }
    .type-dot.numeric     { background: #58a6ff; }
    .type-dot.boolean     { background: #3fb950; }
    .type-dot.datetime    { background: #d29922; }

    .type-name { font-size: 0.88rem; color: var(--ink); flex: 1; }
    .type-count { font-size: 0.88rem; font-weight: 700; color: var(--ink); }

    /* ─── COLUMN PROFILE TABLE ───────────────────────────── */
    .col-name-cell {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .col-name-text {
      font-weight: 600;
      font-family: 'SFMono-Regular', Consolas, monospace;
      font-size: 0.85rem;
    }

    .role-chip {
      display: inline-block;
      padding: 1px 7px;
      border-radius: 999px;
      font-size: 0.68rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--accent);
      background: var(--accent-soft);
      border: 1px solid rgba(163,113,247,0.2);
    }

    /* ─── FOOTER ─────────────────────────────────────────── */
    .footer {
      text-align: center;
      padding: 32px 0;
      border-top: 1px solid var(--border);
      color: var(--dim);
      font-size: 0.8rem;
      margin-top: 20px;
    }

    .footer a { color: var(--accent); text-decoration: none; }
  </style>
</head>
<body>
<div class="layout">

  <!-- TOPBAR -->
  <nav class="topbar">
    <div class="topbar-brand">
      <div class="topbar-icon">🩺</div>
      <span class="topbar-name">Dataset Doctor</span>
    </div>
    <span class="topbar-meta">Generated {{ payload.generated_at }}</span>
  </nav>

  <!-- HERO -->
  <header class="hero">
    <div class="hero-eyebrow">
      <span>⚕️</span> Data Health Report
    </div>
    <h1 class="hero-title">
      <span>{{ payload.profile.source_name }}</span>
    </h1>
    <p class="hero-sub">
      Contextual data quality analysis covering structure, missingness, duplicates,
      semantic types, outliers, and dimensional health scoring.
    </p>
  </header>

  <!-- SCORE SECTION -->
  <div class="score-section">

    <!-- Main score ring -->
    <div class="main-score-card">
      <div class="score-ring-wrap">
        {% set score = payload.score.value %}
        {% set circ = 3.14159 * 2 * 54 %}
        {% set dash = (score / 100) * circ %}
        <svg class="score-ring" viewBox="0 0 120 120">
          <defs>
            <linearGradient id="ring-grad" x1="0%" y1="0%" x2="100%" y2="0%">
              {% if score >= 85 %}
                <stop offset="0%" stop-color="#3fb950"/>
                <stop offset="100%" stop-color="#56d364"/>
              {% elif score >= 60 %}
                <stop offset="0%" stop-color="#d29922"/>
                <stop offset="100%" stop-color="#e3b341"/>
              {% else %}
                <stop offset="0%" stop-color="#f85149"/>
                <stop offset="100%" stop-color="#ff7b72"/>
              {% endif %}
            </linearGradient>
          </defs>
          <!-- Track -->
          <circle cx="60" cy="60" r="54"
            fill="none" stroke="rgba(139,148,158,0.12)"
            stroke-width="9" />
          <!-- Fill -->
          <circle cx="60" cy="60" r="54"
            fill="none" stroke="url(#ring-grad)"
            stroke-width="9"
            stroke-linecap="round"
            stroke-dasharray="{{ "%.1f"|format(dash) }} {{ "%.1f"|format(circ) }}"
            stroke-dashoffset="{{ "%.1f"|format(circ / 4) }}"
            transform="rotate(-90 60 60)" />
        </svg>
        <div class="score-ring-val">
          <span class="score-number">{{ score }}</span>
          <span class="score-denom">/ 100</span>
        </div>
      </div>

      <span class="score-badge {{ payload.score.css_modifier }}">
        {% if payload.score.badge == "Healthy" %}✓{% elif payload.score.badge == "Critical" %}✕{% else %}⚠{% endif %}
        {{ payload.score.badge }}
      </span>

      <div class="score-meta-row">
        <div class="score-meta-item">
          <strong>{{ payload.profile.suspicious_column_count }}</strong>
          <span>Suspicious</span>
        </div>
        <div class="score-meta-item">
          <strong>{{ payload.warnings|length }}</strong>
          <span>Warnings</span>
        </div>
        <div class="score-meta-item">
          <strong>{{ payload.profile.duplicate_rows }}</strong>
          <span>Duplicates</span>
        </div>
      </div>
    </div>

    <!-- Dimension bars -->
    <div class="dim-card">
      <div class="dim-card-title">Dimensional Breakdown</div>

      {% set dims = [
        ("Completeness", payload.score.completeness, "📦"),
        ("Uniqueness",   payload.score.uniqueness,   "🔑"),
        ("Consistency",  payload.score.consistency,  "⚙️"),
        ("Stability",    payload.score.stability,    "📊")
      ] %}

      {% for name, val, icon in dims %}
      <div class="dim-row">
        <div class="dim-header">
          <div class="dim-label">
            <span>{{ icon }}</span>
            {{ name }}
          </div>
          <div class="dim-val">{{ val }}</div>
        </div>
        <div class="dim-track">
          <div class="dim-fill {% if val < 60 %}crit{% elif val < 85 %}warn{% else %}ok{% endif %}"
               style="width: {{ val }}%;"></div>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>

  <!-- OVERVIEW STATS -->
  <section class="section">
    <div class="section-header">
      <div class="section-icon" style="background: rgba(88,166,255,0.12);">📋</div>
      <div class="section-text">
        <h2>Overview</h2>
        <p>Structural snapshot of the dataset at a glance.</p>
      </div>
    </div>
    <div class="stat-grid">
      <div class="stat-card">
        <div class="stat-label">Rows</div>
        <div class="stat-value">{{ payload.profile.row_count }}</div>
        <div class="stat-sub">Total records</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Columns</div>
        <div class="stat-value">{{ payload.profile.column_count }}</div>
        <div class="stat-sub">Detected fields</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Duplicate Rows</div>
        <div class="stat-value" style="{% if payload.profile.duplicate_pct > 5 %}color: var(--warning);{% endif %}">
          {{ payload.profile.duplicate_rows }}
        </div>
        <div class="stat-sub">{{ "%.1f"|format(payload.profile.duplicate_pct) }}% of dataset</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Outlier Columns</div>
        <div class="stat-value" style="{% if payload.profile.outlier_columns|length > 0 %}color: var(--warning);{% endif %}">
          {{ payload.profile.outlier_columns|length }}
        </div>
        <div class="stat-sub">IQR-flagged numerics</div>
      </div>
    </div>
  </section>

  <!-- WARNINGS -->
  <section class="section">
    <div class="section-header">
      <div class="section-icon" style="background: rgba(248,81,73,0.1);">⚠️</div>
      <div class="section-text">
        <h2>Warnings</h2>
        <p>Contextual findings ordered by severity for quick triage.</p>
      </div>
    </div>
    <div class="warning-list">
      {% for w in payload.warnings %}
      <article class="warning-item {{ w.level }}">
        <div class="warning-dot {{ w.level }}"></div>
        <div class="warning-body">
          <div class="warning-top">
            <span class="warning-pill {{ w.level }}">{{ w.level }}</span>
            <span class="warning-title-text">{{ w.title }}</span>
          </div>
          <p class="warning-message">{{ w.message }}</p>
          <div class="warning-action">
            <strong>Action:</strong> {{ w.recommended_action }}
          </div>
        </div>
      </article>
      {% endfor %}
      {% if not payload.warnings %}
      <div style="text-align:center; padding: 32px; color: var(--muted); font-size: 0.9rem;">
        🎉 No warnings generated. Dataset looks clean.
      </div>
      {% endif %}
    </div>
  </section>

  <!-- STRUCTURE SUMMARY -->
  <section class="section">
    <div class="section-header">
      <div class="section-icon" style="background: rgba(163,113,247,0.12);">🗂️</div>
      <div class="section-text">
        <h2>Structure Summary</h2>
        <p>Type distribution and recommended next steps for cleanup.</p>
      </div>
    </div>
    <div class="two-col">

      <!-- Type distribution -->
      <div class="table-wrap" style="padding: 20px 24px;">
        <div style="font-size:0.75rem;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:var(--muted);margin-bottom:12px;border-bottom:1px solid var(--border);padding-bottom:10px;">
          Semantic Types
        </div>
        {% for stype in ["categorical", "numeric", "boolean", "datetime"] %}
        <div class="type-row">
          <div class="type-dot {{ stype }}"></div>
          <div class="type-name">{{ stype | title }}</div>
          <div class="type-count">{{ payload.profile.semantic_type_counts.get(stype, 0) }}</div>
        </div>
        {% endfor %}
      </div>

      <!-- Action card -->
      <div class="action-card">
        <div class="action-card-title">Suggested Actions</div>
        <ul class="action-list">
          {% for action in payload.suggested_actions %}
          <li>{{ action }}</li>
          {% else %}
          <li style="color: var(--muted); list-style: none;">No immediate actions required.</li>
          {% endfor %}
        </ul>
      </div>
    </div>
  </section>

  <!-- PROBLEMATIC COLUMNS -->
  <section class="section">
    <div class="section-header">
      <div class="section-icon" style="background: rgba(210,153,34,0.1);">🔍</div>
      <div class="section-text">
        <h2>Problematic Columns</h2>
        <p>Columns with high missingness, constant values, high-cardinality, or outliers.</p>
      </div>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Column</th>
            <th>Role</th>
            <th>Type</th>
            <th>Missing</th>
            <th>Unique Ratio</th>
            <th>Active Flags</th>
          </tr>
        </thead>
        <tbody>
          {% for col in payload.problematic_columns %}
          <tr>
            <td>
              <div class="col-name-cell">
                <span class="col-name-text">{{ col.name }}</span>
                {% if col.role %}<span class="role-chip">{{ col.role }}</span>{% endif %}
              </div>
            </td>
            <td><span class="code-chip">{{ col.semantic_type }}</span></td>
            <td><span class="code-chip">{{ col.role or '—' }}</span></td>
            <td>{{ "%.1f"|format(col.missing_pct) }}%</td>
            <td>{{ "%.1f"|format(col.unique_ratio * 100) }}%</td>
            <td>
              <div class="flag-list">
                {% for flag in col.flags %}
                  <span class="flag {% if 'missing' in flag %}missing{% elif 'outliers' in flag %}outliers{% else %}default{% endif %}">
                    {{ flag }}
                  </span>
                {% endfor %}
              </div>
            </td>
          </tr>
          {% else %}
          <tr>
            <td colspan="6" style="text-align:center; padding: 32px; color: var(--muted);">
              ✅ No problematic columns detected.
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>

  <!-- NUMERIC FINDINGS -->
  <section class="section">
    <div class="section-header">
      <div class="section-icon" style="background: rgba(88,166,255,0.1);">📈</div>
      <div class="section-text">
        <h2>Numeric Findings</h2>
        <p>Distribution signals and IQR-based outlier bounds for numeric columns.</p>
      </div>
    </div>

    <!-- Stats table -->
    <div class="table-wrap" style="margin-bottom: 16px;">
      <table>
        <thead>
          <tr>
            <th>Column</th>
            <th>Min</th>
            <th>Median</th>
            <th>Mean</th>
            <th>Max</th>
            <th>Std Dev</th>
          </tr>
        </thead>
        <tbody>
          {% for col in payload.numeric_columns %}
          <tr>
            <td><span class="col-name-text">{{ col.name }}</span></td>
            <td>{{ col.numeric_summary.min_value|number }}</td>
            <td>{{ col.numeric_summary.median|number }}</td>
            <td>{{ col.numeric_summary.mean|number }}</td>
            <td>{{ col.numeric_summary.max_value|number }}</td>
            <td>{{ col.numeric_summary.std|number }}</td>
          </tr>
          {% else %}
          <tr>
            <td colspan="6" style="text-align:center; padding:32px; color:var(--muted);">
              No numeric columns available.
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    <!-- IQR table -->
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Column</th>
            <th>Q1</th>
            <th>Q3</th>
            <th>IQR</th>
            <th>Valid Bounds</th>
            <th>Outliers</th>
          </tr>
        </thead>
        <tbody>
          {% for col in payload.numeric_columns %}
          <tr>
            <td><span class="col-name-text">{{ col.name }}</span></td>
            <td>{{ col.numeric_summary.q1|number }}</td>
            <td>{{ col.numeric_summary.q3|number }}</td>
            <td>{{ col.numeric_summary.iqr|number }}</td>
            <td style="color:var(--muted);">
              {{ col.numeric_summary.lower_bound|number }} → {{ col.numeric_summary.upper_bound|number }}
            </td>
            <td>
              <span style="font-weight: 600; {% if col.numeric_summary.outlier_count > 0 %}color: var(--warning);{% else %}color: var(--muted);{% endif %}">
                {{ col.numeric_summary.outlier_count }}
              </span>
              <span style="color:var(--dim); font-size:0.8rem;">
                ({{ "%.1f"|format(col.numeric_summary.outlier_pct) }}%)
              </span>
            </td>
          </tr>
          {% else %}
          <tr>
            <td colspan="6" style="text-align:center; padding:32px; color:var(--muted);">
              No numeric columns available.
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>

</div>

<!-- FOOTER -->
<footer class="footer layout" style="max-width:1140px; margin: 0 auto;">
  <p>
    Generated by <a href="https://github.com/addaan1/dataset-doctor" target="_blank">Dataset Doctor</a>
    &nbsp;·&nbsp; {{ payload.generated_at }}
  </p>
</footer>

</body>
</html>
